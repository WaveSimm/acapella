generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── 곡 ───
model Song {
  id         String             @id @default(cuid())
  titleKo    String             @map("title_ko")
  titleEn    String?            @map("title_en")
  composer   String?
  arranger   String?
  pageNumber Int?               @map("page_number")
  createdAt  DateTime           @default(now()) @map("created_at")
  updatedAt  DateTime           @updatedAt @map("updated_at")

  resources  PracticeResource[]
  specs      ConductorSpec[]
  ensembles  EnsembleSong[]
  rehearsals RehearsalSong[]

  @@map("songs")
}

// ─── 파트별 연습 리소스 ───
model PracticeResource {
  id           String       @id @default(cuid())
  songId       String       @map("song_id")
  conductorId  String?      @map("conductor_id")
  part         String       @default("전체")
  resourceType ResourceType @default(VIDEO) @map("resource_type")
  url          String
  sourceSite   String?      @map("source_site")
  label        String?
  fileId       String?      @unique @map("file_id")
  createdAt    DateTime     @default(now()) @map("created_at")

  song         Song          @relation(fields: [songId], references: [id])
  conductor    Conductor?    @relation(fields: [conductorId], references: [id], onDelete: SetNull)
  file         UploadedFile? @relation(fields: [fileId], references: [id], onDelete: SetNull)

  @@map("practice_resources")
}

// ─── 업로드된 파일 (MIDI, PDF, MP3 등 소형 파일) ───
model UploadedFile {
  id          String            @id @default(cuid())
  fileName    String            @map("file_name")
  mimeType    String            @map("mime_type")
  size        Int
  data        Bytes
  conductorId String?           @map("conductor_id")
  createdAt   DateTime          @default(now()) @map("created_at")

  resource    PracticeResource?

  @@index([conductorId])
  @@map("uploaded_files")
}

enum ResourceType {
  VIDEO
  AUDIO
  SCORE_PREVIEW
  MIDI
}

enum Role {
  PENDING
  CONDUCTOR
  ADMIN
}

// ─── 지휘자 ───
model Conductor {
  id            String             @id @default(cuid())
  name          String
  email         String             @unique
  image         String?
  authProvider  String?            @map("auth_provider")
  region        String?
  bio           String?            @db.Text
  regionPublic  Boolean            @default(false) @map("region_public")
  bioPublic     Boolean            @default(false) @map("bio_public")
  role          Role               @default(PENDING)
  isApproved    Boolean            @default(false) @map("is_approved")
  createdAt     DateTime           @default(now()) @map("created_at")
  updatedAt     DateTime           @updatedAt @map("updated_at")

  specs         ConductorSpec[]
  ensembles     Ensemble[]
  resources     PracticeResource[]
  accounts      Account[]
  sessions      Session[]

  @@map("conductors")
}

// ─── 곡별 음악 사양 ───
model ConductorSpec {
  id              String          @id @default(cuid())
  songId          String          @map("song_id")
  conductorId     String          @map("conductor_id")

  keySignature    String?         @map("key_signature")
  timeSignature   String?         @map("time_signature")
  tempo           String?
  difficulty      Difficulty?
  voicing         String?
  measures        Int?
  highestNote     String?         @map("highest_note")
  soloInfo        String?         @map("solo_info")
  theme           String?
  accompaniment   String?
  durationMin     Float?          @map("duration_min")
  notes           String?         @db.Text

  lastPerformedAt DateTime?       @map("last_performed_at")

  isPublic        Boolean         @default(false) @map("is_public")
  forkedFromId    String?         @map("forked_from_id")

  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")

  song            Song            @relation(fields: [songId], references: [id])
  conductor       Conductor       @relation(fields: [conductorId], references: [id], onDelete: Cascade)
  forkedFrom      ConductorSpec?  @relation("SpecFork", fields: [forkedFromId], references: [id])
  forks           ConductorSpec[] @relation("SpecFork")

  @@unique([songId, conductorId])
  @@map("conductor_specs")
}

enum Difficulty {
  EASY
  BELOW_MID
  MEDIUM
  ABOVE_MID
  HARD
}

// ─── 합창단 ───
model Ensemble {
  id             String         @id @default(cuid())
  conductorId    String         @map("conductor_id")
  name           String
  shareCode      String         @unique @map("share_code")
  description    String?        @db.Text
  driveFolderUrl String?        @map("drive_folder_url")
  driveFolderId  String?        @map("drive_folder_id")
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")

  conductor      Conductor      @relation(fields: [conductorId], references: [id])
  songs          EnsembleSong[]
  rehearsals     Rehearsal[]

  @@map("ensembles")
}

// ─── 연습 일정 ───
model Rehearsal {
  id         String          @id @default(cuid())
  ensembleId String          @map("ensemble_id")
  date       DateTime?       @db.Date
  startTime  String?         @map("start_time")
  location   String?
  note       String?         @db.Text
  createdAt  DateTime        @default(now()) @map("created_at")
  updatedAt  DateTime        @updatedAt @map("updated_at")

  ensemble   Ensemble        @relation(fields: [ensembleId], references: [id], onDelete: Cascade)
  songs      RehearsalSong[]

  @@index([ensembleId, date])
  @@map("rehearsals")
}

model RehearsalSong {
  id          String    @id @default(cuid())
  rehearsalId String    @map("rehearsal_id")
  songId      String    @map("song_id")
  orderIdx    Int       @default(0) @map("order_idx")
  note        String?
  addedAt     DateTime  @default(now()) @map("added_at")

  rehearsal   Rehearsal @relation(fields: [rehearsalId], references: [id], onDelete: Cascade)
  song        Song      @relation(fields: [songId], references: [id])

  @@unique([rehearsalId, songId])
  @@map("rehearsal_songs")
}

// ─── 합창단 레파토리 (곡 목록) ───
model EnsembleSong {
  id         String   @id @default(cuid())
  ensembleId String   @map("ensemble_id")
  songId     String   @map("song_id")
  orderIdx   Int      @default(0) @map("order_idx")
  note       String?  @db.Text
  addedAt    DateTime @default(now()) @map("added_at")

  ensemble   Ensemble @relation(fields: [ensembleId], references: [id], onDelete: Cascade)
  song       Song     @relation(fields: [songId], references: [id])

  @@unique([ensembleId, songId])
  @@map("ensemble_songs")
}

// ─── NextAuth ───
model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user              Conductor @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String    @id @default(cuid())
  sessionToken String    @unique @map("session_token")
  userId       String    @map("user_id")
  expires      DateTime

  user         Conductor @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─── 접속 로그 ───
model AccessLog {
  id          String   @id @default(cuid())
  ip          String?
  userAgent   String?  @map("user_agent")
  path        String
  pageType    String   @map("page_type")
  shareCode   String?  @map("share_code")
  conductorId String?  @map("conductor_id")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([pageType, createdAt])
  @@index([shareCode, createdAt])
  @@index([conductorId, createdAt])
  @@map("access_logs")
}
